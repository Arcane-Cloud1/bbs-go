{
  "name": "bbs-go",
  "version": "1.0.0",
  "description": "BBS-GO 社区系统 - EdgeOne 部署版本",
  "main": "cloud-functions/api.go",
  "scripts": {
    "dev": "edgeone pages dev",
    "deploy": "edgeone pages deploy"
  },
  "edgeone": {
    "framework": "gin",
    "runtime": "go",
    "buildCommand": "go build -o api ./cloud-functions",
    "outputDirectory": ".",
    "installCommand": "go mod download",
    "functions": {
      "api": {
        "runtime": "go",
        "handler": "cloud-functions/api.go",
        "memorySize": 512,
        "timeout": 30
      }
    }
  },
  "engines": {
    "go": ">=1.21"
  }
}
